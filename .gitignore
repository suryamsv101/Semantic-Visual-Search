visual-search-app/backend/data/*
visual-search-app/backend/images/*

# ...but DO NOT ignore the .gitkeep files (this keeps the folder structure intact on GitHub)
!visual-search-app/backend/data/.gitkeep
!visual-search-app/backend/images/.gitkeep

